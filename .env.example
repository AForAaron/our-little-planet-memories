# demo：只用本地演示数据；live：启用 Neon Auth / Postgres / R2。
# 在数据库迁移、两个 profile 和 R2 CORS 都完成前不要改成 live。
APP_DATA_MODE=demo

# Neon Postgres（使用 pooled connection string）
DATABASE_URL=

# Neon Auth
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=

# Cloudflare R2 私有 bucket
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=our-little-planet-memories

# 地点搜索。配置高德 Web 服务 Key 时默认优先高德，否则使用 OSM。
AMAP_WEB_SERVICE_KEY=
GEOCODING_PROVIDER=amap
GEOCODING_USER_AGENT=OurLittlePlanetMemories/1.0 (private couple memories site)

# 唯一允许访问网站的两个邮箱
ALLOWLIST_EMAILS=you@example.com,partner@example.com

# 本地审核台可选：用于按聊天原文生成一句可编辑的 AI 记忆短评
AI_SUMMARY_PROVIDER=glm
GLM_API_KEY=
GLM_MODEL=glm-4.7-flash

# 如需切换 OpenAI，将 AI_SUMMARY_PROVIDER 改为 openai 后填写下面两项
OPENAI_API_KEY=
OPENAI_MODEL=

# 发布时关联到 entries.author_id 的 Neon profile id
IMPORT_AUTHOR_ID=

# 不要长期写入 .env；仅在确认实际发布的命令中临时设置为 YES
PUBLISH_CONFIRMED=

# 本地审核台由 npm run review 自动设置，不要在 Vercel 中启用。
# 启动审核台前必须设置一个高强度访问码。
IMPORT_REVIEW_MODE=0
REVIEW_ACCESS_TOKEN=
REVIEW_SELF_LABEL=张张
REVIEW_PARTNER_LABEL=沈沈

# 必须是源码目录之外的绝对路径；缺失时导入工具拒绝运行。
IMPORT_DATA_ROOT=/absolute/path/to/Web-private/raw
IMPORT_WORK_ROOT=/absolute/path/to/Web-private/work/import
IMPORT_PUBLISH_ROOT=/absolute/path/to/Web-private/publish
